import scrapy

class JobItem(scrapy.Item):
    title = scrapy.Field()
    salary = scrapy.Field()

#spider.py
import scrapy
class JpbSpider(scrapy.Spider):
    name = "jodon"
    start_urls = ["https://www.BOSSZHAOPIN.com"]
    def parse(self,response)
        item = JobItem()
        item['title'] = response.xpath("//title/text()").get()
        yield item

